# Make a copy of this for local development:
# cp .env.example .env

DATABRICKS_CONFIG_PROFILE=DEFAULT
DATABRICKS_HOST=https://dbc-de840360-1abb.cloud.databricks.com
# Prefer OAuth for Databricks Apps development:
# databricks auth login --host https://dbc-de840360-1abb.cloud.databricks.com

# MLflow trace experiment. The Databricks quickstart can create this for you.
MLFLOW_EXPERIMENT_ID=
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc

# App/frontend settings.
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
NEO4J_MAX_ROWS=25
DATABRICKS_AGENT_MODEL=databricks-claude-sonnet-4-5

# Local-only option: point at the downloaded Neo4j credential file instead of
# copying secrets into this file.
# NEO4J_CREDENTIAL_FILE=/Users/gsivaji/Documents/Neo4j/Databricks/agentbricks/Neo4j-27ad415a-Created-2025-11-12.txt

# Local-only direct env vars, if you choose not to use NEO4J_CREDENTIAL_FILE.
# NEO4J_URI=
# NEO4J_USERNAME=
# NEO4J_PASSWORD=
# NEO4J_DATABASE=
